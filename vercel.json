{
  "rewrites": [
    {
      "source": "/graphql",
      "destination": "https://finflow-api-6sda.onrender.com/graphql"
    },
    {
      "source": "/api/:path*",
      "destination": "https://finflow-api-6sda.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://finflow-api-6sda.onrender.com/uploads/:path*"
    },
    {
      "source": "/health",
      "destination": "https://finflow-api-6sda.onrender.com/health"
    },
    {
      "source": "/((?!graphql|api|uploads|health).*)",
      "destination": "/index.html"
    }
  ]
}
